# Outlook / Microsoft Graph (email fetch)
IMAP_EMAIL=your_outlook_address@outlook.com
# On Railway: paste the value from /email-token-export here after first login
MSAL_TOKEN_CACHE=

# Dropbox Configuration
DROPBOX_ACCESS_TOKEN=your_dropbox_access_token_here
DROPBOX_EXCEL_PATH=/Church/Excel

# Website Configurations
PREEKROSTER_URL=https://your-church-website.com/preekroster
SCIPIO_BASE_URL=https://scipio.your-provider.com
SCIPIO_USERNAME=your_username
SCIPIO_PASSWORD=your_password

# Output Configuration
OUTPUT_DIR=./output
TEMPLATE_DIR=./templates

# Bulletin Configuration
CHURCH_NAME=Uw Gemeente Naam
BULLETIN_LANGUAGE=nl

# Google Sheets (fallback for liederen when email not found)
# Option 1: Path to service account JSON file (local development)
# GOOGLE_SERVICE_ACCOUNT_PATH=./.google_service_account.json
# Option 2: JSON content as environment variable (Railway/Heroku)
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
